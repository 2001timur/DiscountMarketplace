@page "/users"
@using DiscountMarketplace.Models
@using DiscountMarketplace.Interfaces
@rendermode InteractiveServer
@inject IUserService UserService
@inject NavigationManager NavManager

<PageTitle>Керування користувачами</PageTitle>

<div class="container mt-4">
   
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @statusClass alert-dismissible fade show" role="alert">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Користувачі</h2>
        <button class="btn btn-primary" @onclick="PrepareCreate">
            <i class="bi bi-plus-circle"></i> Додати користувача
        </button>
    </div>

    @if (users == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Завантаження...</p>
        </div>
    }
    else
    {
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Ім'я</th>
                    <th>Email</th>
                    <th>Телефон</th>
                    <th>Роль</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr>
                        <td>@user.FirstName @user.LastName</td>
                        <td>@user.Email</td>
                        <td>@user.Phone</td>
                        <td><span class="badge bg-info text-dark">@user.Role</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-warning me-2" @onclick="() => PrepareEdit(user)">Редагувати</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(user.UserId)">Видалити</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (isEditing)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(currentUser.UserId == 0 ? "Створити" : "Редагувати") користувача</h5>
                    <button type="button" class="btn-close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">
                    @* Повідомлення про помилку всередині модалки *@
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger">@modalError</div>
                    }

                    <EditForm Model="@currentUser" OnValidSubmit="SaveUser">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small" />

                        <div class="mb-3">
                            <label class="form-label">Ім'я</label>
                            <InputText class="form-control" @bind-Value="currentUser.FirstName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Прізвище</label>
                            <InputText class="form-control" @bind-Value="currentUser.LastName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText class="form-control" @bind-Value="currentUser.Email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Телефон</label>
                            <InputText class="form-control" @bind-Value="currentUser.Phone" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Роль</label>
                            <InputSelect class="form-control" @bind-Value="currentUser.Role">
                                <option value="Customer">Customer</option>
                                <option value="BusinessOwner">BusinessOwner</option>
                                <option value="Admin">Admin</option>
                            </InputSelect>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="button" class="btn btn-secondary me-2" @onclick="Cancel">Скасувати</button>
                            <button type="submit" class="btn btn-success">Зберегти</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<User>? users;
    private User currentUser = new();
    private bool isEditing = false;

    private string? statusMessage;
    private string statusClass = "alert-success";
    private string? modalError;

    protected override void OnInitialized()
    {
        LoadUsers();
    }

    private void LoadUsers()
    {
        try
        {
            users = UserService.GetAll();
        }
        catch (Exception ex)
        {
            ShowStatus("Помилка завантаження даних: " + ex.Message, false);
        }
    }

    private void PrepareCreate()
    {
        modalError = null;
        currentUser = new User { Role = "Customer" };
        isEditing = true;
    }

    private void PrepareEdit(User user)
    {
        modalError = null;
        currentUser = new User
            {
                UserId = user.UserId,
                FirstName = user.FirstName,
                LastName = user.LastName,
                Email = user.Email,
                Phone = user.Phone,
                Role = user.Role,
                PasswordHash = user.PasswordHash
            };
        isEditing = true;
    }

    private void SaveUser()
    {
        try
        {
            modalError = null;
            if (currentUser.UserId == 0)
            {
                currentUser.PasswordHash = "temporary_hash";
                UserService.Create(currentUser);
                ShowStatus("Користувача успішно створено!");
            }
            else
            {
                UserService.Update(currentUser);
                ShowStatus("Дані користувача оновлено!");
            }

            isEditing = false;
            LoadUsers();
        }
        catch (Exception ex)
        {
            modalError = "Не вдалося зберегти: " + ex.Message;
        }
    }

    private void DeleteUser(int id)
    {
        try
        {
            UserService.Delete(id);
            ShowStatus("Користувача видалено.");
            LoadUsers();
        }
        catch (Exception ex)
        {
            ShowStatus("Помилка видалення: " + ex.Message, false);
        }
    }

    private void ShowStatus(string message, bool isSuccess = true)
    {
        statusMessage = message;
        statusClass = isSuccess ? "alert-success" : "alert-danger";

        Task.Delay(5000).ContinueWith(_ =>
        {
            statusMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private void Cancel()
    {
        isEditing = false;
        modalError = null;
    }
}