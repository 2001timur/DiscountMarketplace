@page "/categories"
@using DiscountMarketplace.Models
@using DiscountMarketplace.Interfaces
@rendermode InteractiveServer
@inject IServiceCategoryService CategoryService

<PageTitle>Керування категоріями</PageTitle>

<div class="container mt-4">
 
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @statusClass alert-dismissible fade show" role="alert">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Категорії послуг</h2>
        <button class="btn btn-primary" @onclick="PrepareCreate">
            <i class="bi bi-plus-circle"></i> Додати категорію
        </button>
    </div>

    @if (categories == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p><em>Завантаження...</em></p>
        </div>
    }
    else
    {
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Іконка</th>
                    <th>Назва</th>
                    <th>Опис</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in categories)
                {
                    <tr>
                        <td style="width: 50px;">
                            @if (!string.IsNullOrEmpty(cat.IconUrl))
                            {
                                <img src="@cat.IconUrl" alt="icon" style="width: 32px; height: 32px; object-fit: contain;" />
                            }
                        </td>
                        <td><strong>@cat.Name</strong></td>
                        <td>@cat.Description</td>
                        <td>
                            <button class="btn btn-sm btn-outline-warning me-2" @onclick="() => PrepareEdit(cat)">Редагувати</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCategory(cat.CategoryId)">Видалити</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (isEditing)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(currentCategory.CategoryId == 0 ? "Нова категорія" : "Редагування категорії")</h5>
                    <button type="button" class="btn-close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">
                    @* Повідомлення про помилку всередині модального вікна *@
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger">@modalError</div>
                    }

                    <EditForm Model="@currentCategory" OnValidSubmit="SaveCategory">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small" />

                        <div class="mb-3">
                            <label class="form-label">Назва категорії</label>
                            <InputText class="form-control" @bind-Value="currentCategory.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Опис</label>
                            <InputTextArea class="form-control" @bind-Value="currentCategory.Description" rows="3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">URL Іконки</label>
                            <InputText class="form-control" @bind-Value="currentCategory.IconUrl" placeholder="https://example.com/icon.png" />
                        </div>

                        <div class="d-flex justify-content-end mt-3">
                            <button type="button" class="btn btn-secondary me-2" @onclick="Cancel">Скасувати</button>
                            <button type="submit" class="btn btn-success">Зберегти</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Servicecategory>? categories;
    private Servicecategory currentCategory = new();
    private bool isEditing = false;

    private string? statusMessage;
    private string statusClass = "alert-success";
    private string? modalError;

    protected override void OnInitialized()
    {
        LoadCategories();
    }

    private void LoadCategories()
    {
        try
        {
            categories = CategoryService.GetAll();
        }
        catch (Exception ex)
        {
            ShowStatus("Помилка завантаження категорій: " + ex.Message, false);
        }
    }

    private void PrepareCreate()
    {
        modalError = null;
        currentCategory = new Servicecategory();
        isEditing = true;
    }

    private void PrepareEdit(Servicecategory cat)
    {
        modalError = null;
        currentCategory = new Servicecategory
            {
                CategoryId = cat.CategoryId,
                Name = cat.Name,
                Description = cat.Description,
                IconUrl = cat.IconUrl
            };
        isEditing = true;
    }

    private void SaveCategory()
    {
        try
        {
            modalError = null;
            if (currentCategory.CategoryId == 0)
            {
                CategoryService.Create(currentCategory);
                ShowStatus("Категорію успішно створено!");
            }
            else
            {
                CategoryService.Update(currentCategory);
                ShowStatus("Категорію успішно оновлено!");
            }

            isEditing = false;
            LoadCategories();
        }
        catch (Exception ex)
        {
            modalError = "Не вдалося зберегти категорію: " + ex.Message;
        }
    }

    private void DeleteCategory(int id)
    {
        try
        {
            CategoryService.Delete(id);
            ShowStatus("Категорію видалено.");
            LoadCategories();
        }
        catch (Exception ex)
        {
            ShowStatus("Не вдалося видалити категорію: " + ex.Message, false);
        }
    }

    private void ShowStatus(string message, bool isSuccess = true)
    {
        statusMessage = message;
        statusClass = isSuccess ? "alert-success" : "alert-danger";

        Task.Delay(5000).ContinueWith(_ =>
        {
            statusMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private void Cancel()
    {
        isEditing = false;
        modalError = null;
    }
}