@page "/"
@page "/login"
@using DiscountMarketplace.Models
@using DiscountMarketplace.Services
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

@inject MarketplaceContext db
@inject NavigationManager Nav
@inject AuthService Auth

<h3>Вхід</h3>

<div class="mb-3">
    <label>Логін (Email)</label>
    <InputText @bind-Value="login" class="form-control" placeholder="example@mail.com" />
</div>

<div class="mb-3">
    <label>Пароль</label>
    <input type="password" @bind="password" class="form-control" />
</div>

<button class="btn btn-primary" @onclick="LoginUser">
    Увійти
</button>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger mt-3">
        @error
    </div>
}

@code {
    private string login = "";
    private string password = "";
    private string error = "";

    private void LoginUser()
    {
        error = "";

        try
        {
            if (string.IsNullOrWhiteSpace(login) || string.IsNullOrWhiteSpace(password))
            {
                error = "Будь ласка, заповніть усі поля";
                return;
            }

            var user = db.Users.FirstOrDefault(x =>
                x.Email == login &&
                x.PasswordHash == password);

            if (user == null)
            {
                error = "Невірний логін або пароль";
                password = ""; 
                return;
            }

            Auth.Login(user);
            string role = user.Role?.Trim().ToLower() ?? "";

            switch (role)
            {
                case "admin":
                    Nav.NavigateTo("/admin");
                    break;
                case "customer":
                    Nav.NavigateTo("/customer");
                    break;
                case "businessowner":
                    Nav.NavigateTo("/businessowner");
                    break;
                default:
                    error = $"Користувач має невідому роль: {user.Role}";
                    break;
            }
        }
        catch (Exception ex)
        {
            error = $"Критична помилка: {ex.Message}";
        }
        finally
        {
            StateHasChanged();
        }
    }
}