@page "/"
@page "/login"
@using DiscountMarketplace.Interfaces
@using DiscountMarketplace.Models
@using DiscountMarketplace.Services
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

@inject MarketplaceContext db
@inject NavigationManager Nav
@inject AuthService Auth
@inject IUserService UserService

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow-sm p-4" style="width: 100%; max-width: 400px;">
        <h3 class="text-center mb-4">Вхід</h3>

        <div class="mb-3">
            <label class="form-label">Логін (Email)</label>
            <InputText @bind-Value="login" class="form-control" placeholder="example@mail.com" />
        </div>

        <div class="mb-3">
            <label class="form-label">Пароль</label>
            <input type="password" @bind="password" class="form-control" placeholder="••••••••" />
        </div>

        <button class="btn btn-primary w-100 mt-2" @onclick="LoginUser">
            Увійти
        </button>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger mt-3 py-2 text-center" style="font-size: 0.9rem;">
                @error
            </div>
        }
    </div>
</div>

@code {
    // Весь ваш код логіки залишається без змін
    private string login = "";
    private string password = "";
    private string error = "";

    private void LoginUser()
    {
        error = "";
        try
        {
            if (string.IsNullOrWhiteSpace(login) || string.IsNullOrWhiteSpace(password))
            {
                error = "Будь ласка, заповніть усі поля";
                return;
            }

            var user = UserService.Authenticate(login, password);

            if (user == null)
            {
                error = "Невірний логін або пароль";
                password = "";
                return;
            }

            Auth.Login(user);
            string role = user.Role?.Trim().ToLower() ?? "";

            switch (role)
            {
                case "admin":
                    Nav.NavigateTo("/admin");
                    break;
                case "customer":
                    Nav.NavigateTo("/customer");
                    break;
                case "businessowner":
                    Nav.NavigateTo("/businessowner");
                    break;
                default:
                    error = $"Користувач має невідому роль: {user.Role}";
                    break;
            }
        }
        catch (Exception ex)
        {
            error = $"Критична помилка: {ex.Message}";
        }
        finally
        {
            StateHasChanged();
        }
    }
}