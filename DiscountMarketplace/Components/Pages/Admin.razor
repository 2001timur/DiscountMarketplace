@page "/admin"

@using DiscountMarketplace.Services

@inject AuthService Auth
@inject NavigationManager Nav

<h3>Адмін-панель</h3>

@code {

    protected override void OnInitialized()
    {
        if (Auth.CurrentUser == null || !Auth.IsAdmin)
        {
            Nav.NavigateTo("/login");
            return;
        }
    }

}